# Telegram
BOT_TOKEN=your-telegram-bot-token
WEBAPP_URL=https://your-webapp-url.com

# --- LLM Provider: "groq" (бесплатно) или "openai" (платно) ---
LLM_PROVIDER=groq

# Groq (БЕСПЛАТНО — зарегистрируйся на https://console.groq.com)
GROQ_API_KEY=gsk_your-groq-api-key

# OpenAI (опционально, если LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini

# --- Embeddings Provider: "huggingface" (бесплатно) или "openai" ---
EMBEDDING_PROVIDER=huggingface

# HuggingFace (БЕСПЛАТНО — получи токен на https://huggingface.co/settings/tokens)
HF_API_KEY=hf_your-huggingface-token

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/second_brain
DB_HOST=localhost
DB_PORT=5432
DB_NAME=second_brain
DB_USER=postgres
DB_PASSWORD=postgres

# Scheduler
DAILY_DIGEST_HOUR=9

# ── Security ──
# Comma-separated Telegram user IDs allowed to use bot (empty = everyone)
ALLOWED_USERS=
# Comma-separated admin Telegram user IDs
ADMIN_IDS=
# Only allow private chats (true/false)
PRIVATE_ONLY=true
# Max input text length (chars)
MAX_TEXT_LENGTH=50000
# Max URL fetches per user per hour
MAX_URL_PER_HOUR=20
# Max extracted content length per source
MAX_CONTENT_CHARS=120000

# ── Delivery mode ──
# When true, bot receives updates via Telegram webhook instead of long polling.
# Requires a public HTTPS URL (Fly.io provides one automatically).
USE_WEBHOOK=false
WEBHOOK_PUBLIC_URL=
WEBHOOK_PATH=/tg/webhook
# Shared secret Telegram attaches to every webhook request (recommended)
WEBHOOK_SECRET=
# Port the internal HTTP server binds to
WEB_PORT=8080

# ── Redis cache (opt-in) ──
# Example: redis://default:password@host:6379
REDIS_URL=
# TTL for cached embeddings (seconds, default 30 days)
EMBEDDING_CACHE_TTL=2592000

# ── Notion integration ──
# Set to false to disable /notion_* commands
NOTION_ENABLED=true

# ── Cryptography ──
# Dedicated secret for encrypting stored credentials (Notion tokens).
# Generate once with: python -c "import secrets; print(secrets.token_urlsafe(48))"
# Keep this stable — rotating it invalidates every encrypted token.
SECRET_KEY=
